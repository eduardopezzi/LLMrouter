# Set this to protect /v1/* and /admin/* endpoints.
LLMROUTER_SERVER__API_KEY=
# Increase to distribute concurrent requests across multiple CPU cores.
LLMROUTER_SERVER__WORKERS=1

# When running in Docker on macOS/Windows, host.docker.internal reaches Ollama on the host.
LLMROUTER_PROVIDERS__OLLAMA__BASE_URL=http://host.docker.internal:11434
LLMROUTER_EVALUATOR__OLLAMA__BASE_URL=http://host.docker.internal:11434

# Optional fallback provider keys.
# NVIDIA_NIM_API_KEY=
# ZAI_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
